{
    "compilerOptions": {
        "types": [
            "mocha",
            "node"
        ],
        "typeRoots": [
            "./node_modules/@types"
        ],
        "lib": [
            "es2022"
        ],
        "module": "commonjs",
        "target": "es2022",
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "skipLibCheck": true
    }
}